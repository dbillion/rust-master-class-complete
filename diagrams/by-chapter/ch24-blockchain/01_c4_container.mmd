classDiagram
    title Blockchain Project Architecture
    
    class Miner {
        +create_block()
        +mine(difficulty)
    }
    
    class User {
        +add_transaction()
    }
    
    class BlockchainApp {
        +main.rs
        +CLI menu
        +run()
    }
    
    class BlockchainModule {
        -blocks: Vec~Block~
        +add_block()
        +verify()
    }
    
    class BlockModule {
        -index: u64
        -hash: String
        -prev_hash: String
        +calculate_hash()
    }
    
    class HashModule {
        +sha256(data) String
        +verify() bool
    }
    
    class Sha2Crate {
        <<external>>
        +Sha256::digest()
    }
    
    class MinerWorker {
        +proof_of_work()
        +find_nonce()
    }
    
    Miner --> BlockchainApp : Uses CLI
    User --> BlockchainApp : Adds blocks
    BlockchainApp --> BlockchainModule : Manages
    BlockchainModule --> BlockModule : Contains Vec
    BlockModule --> HashModule : Uses
    HashModule --> Sha2Crate : Imports
    MinerWorker --> HashModule : Brute force
    MinerWorker --> BlockModule : Updates nonce

sequenceDiagram
    participant Miner
    participant Blockchain
    participant Block
    participant Hash
    participant Latest
    
    Miner->>Blockchain: add_block("data")
    activate Blockchain
    Blockchain->>Latest: get_latest()
    Latest-->>Blockchain: hash: "abc123"
    
    Blockchain->>Block: new(index, data, prev)
    activate Block
    Block->>Block: index = len()
    Block->>Block: timestamp = now()
    Block->>Block: prev_hash = "abc123"
    Block->>Block: nonce = 0
    
    loop Mining (Brute Force)
        Block->>Hash: SHA256(data + nonce)
        activate Hash
        Hash-->>Block: "xyz789..."
        deactivate Hash
        Block->>Block: Check: starts with "0000"?
        alt Hash valid
            Block-->>Blockchain: Mined!
        else Hash invalid
            Block->>Block: nonce += 1
        end
    end
    
    deactivate Block
    Blockchain->>Blockchain: push to Vec
    Blockchain-->>Miner: Success
    
    Note over Miner,Latest: Difficulty = leading zeros

stateDiagram-v2
    title Chapter 4: Loop Lifecycle State Machine
    
    [*] --> LoopStart : Start loop
    
    LoopStart --> LoopCondition : Check condition
    
    state LoopCondition {
        [*] --> ConditionCheck
        ConditionCheck --> TrueBranch : true
        ConditionCheck --> FalseBranch : false
    }
    
    TrueBranch --> LoopBody : Execute body
    LoopBody --> BreakCheck : Check for break
    
    BreakCheck --> LoopEnd : break
    BreakCheck --> ContinueCheck : continue?
    
    ContinueCheck --> LoopStart : continue (skip rest)
    ContinueCheck --> LoopIncrement : next iteration
    
    LoopIncrement --> LoopStart : Update counter
    
    FalseBranch --> LoopEnd : Exit loop
    
    LoopEnd --> [*] : Loop complete
    
    state ForLoop {
        [*] --> Iterator : Get iterator
        Iterator --> NextItem : next()
        NextItem --> SomeItem : Some(item)
        NextItem --> NoneItem : None
        SomeItem --> ForBody : Execute with item
        ForBody --> NextItem
        NoneItem --> ForEnd
        ForEnd --> [*]
    }
    
    note right of LoopCondition
        while: checks before body
        loop: always true
        for: iterator based
    end note

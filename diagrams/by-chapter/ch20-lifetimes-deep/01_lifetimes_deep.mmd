classDiagram
    class LifetimeAnnotations {
        &'a T
        &'a mut T
        fn foo(&'a T)
        Struct<'a>
    }
    
    class LifetimeElision {
        Input lifetime
        Output lifetime
        Self lifetime
        Compiler infers
    }
    
    class LifetimeBounds {
        T: 'a
        &'a T: 'b
        where T: 'a
    }
    
    LifetimeAnnotations --> LifetimeElision : Compiler simplifies
    LifetimeBounds --> LifetimeAnnotations : Constrains lifetimes
    
    Note over LifetimeAnnotations: Prevents dangling references - Ensures reference validity

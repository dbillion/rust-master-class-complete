classDiagram
    title Chapter 6: Generics and Option/Result Enums
    
    class Option~T~ {
        <<enum>>
        +Some(T)
        +None
        +is_some() bool
        +is_none() bool
        +unwrap() T
        +unwrap_or(default: T) T
        +map(F) Option~U~
        +and_then(F) Option~U~
    }
    
    class Result~T, E~ {
        <<enum>>
        +Ok(T)
        +Err(E)
        +is_ok() bool
        +is_err() bool
        +unwrap() T
        +unwrap_err() E
        +unwrap_or(default: T) T
        +map(F) Result~U, E~
    }
    
    class GenericStruct~T~ {
        <<struct>>
        -value: T
        +new(value: T) GenericStruct~T~
        +get_value() &T
        +set_value(value: T)
    }
    
    class GenericTrait~T~ {
        <<trait>>
        +fn process(item: T) -> T
        +fn describe() -> String
    }
    
    Option~T~ <|-- Some : variant
    Option~T~ <|-- None : variant
    Result~T, E~ <|-- Ok : variant
    Result~T, E~ <|-- Err : variant
    
    GenericTrait~T~ <|.. GenericStruct~T~ : implements
    
    Note over Option~T~: Used for nullable values
    Note over Result~T, E~: Used for error handling

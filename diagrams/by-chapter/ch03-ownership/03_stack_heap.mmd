flowchart LR
    subgraph stack["Stack Memory (Fast)"]
        direction TB
        stack_frame["Stack Frame"]
        ptr["ptr: address"]
        len["len: 8"]
        cap["capacity: 8"]
    end
    
    subgraph heap["Heap Memory (Dynamic)"]
        direction TB
        heap_data["String: 'hello'"]
    end
    
    stack --x heap
    
    subgraph owner["Owner"]
        owner_var["String Variable"]
    end
    
    owner_var -.-> ptr
    
    style stack fill:#b2f2bb,stroke:#047857
    style heap fill:#ffd8a8,stroke:#c2410c
    style owner fill:#a5d8ff,stroke:#1e40af
